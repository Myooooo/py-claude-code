# ============================================
# Py Claude Code 环境变量配置
# ============================================
# 复制此文件为 .env 并填写你的配置
# cp .env.example .env
# ============================================

# ============================================
# OpenAI API 配置（必需）
# ============================================

# OpenAI API 密钥（必需）
# 获取地址：https://platform.openai.com/api-keys
OPENAI_API_KEY=your-api-key-here

# API 基础 URL（可选，默认使用 OpenAI 官方）
# 如果使用第三方 API 服务，请修改此处
OPENAI_BASE_URL=https://api.openai.com/v1

# 使用的模型（可选，默认 gpt-4o）
# 可选值：gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo 等
OPENAI_MODEL=gpt-4o

# ============================================
# 生成参数配置（可选）
# ============================================

# 最大生成 token 数（可选，默认 4096）
# 控制单次响应的最大长度
MAX_TOKENS=4096

# 采样温度（可选，默认 0.7）
# 范围 0-2，值越高创造性越强，值越低越稳定
TEMPERATURE=0.7

# ============================================
# 上下文管理配置（可选）
# ============================================

# 最大上下文 token 数（可选，默认 100000）
# 超过此限制将自动压缩历史对话
MAX_CONTEXT_TOKENS=100000

# 最大上下文消息数（已废弃，请使用 MAX_CONTEXT_TOKENS）
# MAX_CONTEXT_MESSAGES=50

# ============================================
# 工具与持久化配置（可选）
# ============================================

# 是否启用工具结果自动摘要（可选，默认 true）
# 工具输出超过 1000 tokens 时自动摘要，节省上下文空间
ENABLE_TOOL_SUMMARIZATION=true

# 是否启用会话持久化（可选，默认 true）
# 启用后会话数据将存储在 SQLite 数据库中
ENABLE_SESSION_PERSISTENCE=true

# 会话数据库存储路径（可选，默认 .claude_sessions.db）
SESSION_DB_PATH=.claude_sessions.db

# 最大工具调用迭代次数（可选，默认 10）
# 防止工具调用无限循环
MAX_TOOL_ITERATIONS=10

# ============================================
# UI 配置（可选）
# ============================================

# 代码高亮主题（可选，默认 monokai）
# 可选值：monokai, dracula, solarized-dark, github-dark 等
THEME=monokai

# 代码显示宽度（可选，默认 120）
CODE_WIDTH=120

# ============================================
# 系统提示词配置（可选）
# ============================================

# 自定义系统提示词（可选，默认使用内置提示词）
# 支持多行，使用 """ 包裹
# SYSTEM_PROMPT="""
# 你是一个专业的编程助手...
# """

# ============================================
# 配置说明
# ============================================
# 
# 1. 必需配置：
#    - OPENAI_API_KEY: 必须设置为有效的 OpenAI API 密钥
#
# 2. 常用配置：
#    - OPENAI_MODEL: 根据需求选择模型（gpt-4o 推荐）
#    - MAX_CONTEXT_TOKENS: 长对话时适当增大
#    - ENABLE_TOOL_SUMMARIZATION: 工具输出长时建议开启
#
# 3. 高级配置：
#    - 一般不需要修改，使用默认值即可
#
# ============================================
